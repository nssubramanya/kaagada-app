{
  "name": "kaagada-app",
  "version": "1.0.0",
  "description": "Duolingo-style Kannada language learning app",
  "main": "backend/server.js",
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix frontend\" \"npm start --prefix backend\"",
    "build": "npm run build --prefix frontend",
    "start": "npm start --prefix backend",
    "vercel-build": "npm run build --prefix frontend",
    "test": "npm-run-all --parallel \"test:frontend\" \"test:backend\"",
    "test:frontend": "npm run test --prefix frontend",
    "test:backend": "npm run test --prefix backend",
    "prepare": "husky install"
  },
  "keywords": [
    "kannada",
    "language-learning",
    "duolingo",
    "react",
    "express"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "npm-run-all": "^4.1.5"
  },
  "lint-staged": {
    "*.{js,jsx}": []
  }
}
